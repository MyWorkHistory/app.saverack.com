# Copy to `.env.local` (recommended for local) or `.env.development`.
# Next.js loads `.env.local` in all modes and overrides other env files.

NODE_ENV=development

# MySQL on your machine (create DB `saverack_net` or similar).
# No password: mysql://root@localhost:3306/saverack_net
# With password: mysql://root:PASSWORD@localhost:3306/saverack_net (encode ! # etc. in PASSWORD)
DATABASE_URL="mysql://root@localhost:3306/saverack_net"

# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="dev_replace_with_random_string"

# Local app URL
NEXTAUTH_URL="http://localhost:3000"
