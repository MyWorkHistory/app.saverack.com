# Do NOT commit real secrets. On the server, set these in cPanel "Environment"
# or copy to `.env.production.local` (never commit that file).

NODE_ENV=production

# MySQL from cPanel (use the hostname/port cPanel shows, often localhost)
DATABASE_URL="mysql://cpanel_db_user:STRONG_PASSWORD@localhost:3306/cpanel_db_name"

NEXTAUTH_SECRET="production_use_long_random_secret_openssl_rand_base64_32"

# Public URL of your deployed app (https)
NEXTAUTH_URL="https://your-domain.com"
