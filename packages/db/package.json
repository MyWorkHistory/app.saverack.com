{
  "name": "@crm/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "db:generate": "dotenv -e ../../.env -e ../../.env.local -e ../../apps/web/.env.local -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -e ../../.env.local -e ../../apps/web/.env.local -- prisma migrate dev",
    "db:studio": "dotenv -e ../../.env -e ../../.env.local -e ../../apps/web/.env.local -- prisma studio",
    "db:seed": "dotenv -e ../../.env -e ../../.env.local -e ../../apps/web/.env.local -- prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.17.1"
  }
}
