# Quick start: copy `.env.development.example` → `.env.local` and edit values.
# See docs/environment.md for local vs production setup.

# No local password: mysql://root@localhost:3306/saverack_net
# With password: mysql://root:password@localhost:3306/saverack_net (URL-encode special chars in password).
DATABASE_URL="mysql://root@localhost:3306/saverack_net"
NEXTAUTH_SECRET="replace_me_with_a_long_random_string"
NEXTAUTH_URL="http://localhost:3000"

# Set to "false" to disable the dev-only design login (see auth.ts)
# AUTH_DEV_BYPASS="false"

# Same paths as old Laravel public/: copy files into apps/web/public/
# NEXT_PUBLIC_CRM_LOGO_PATH="/assets/images/logo.png"
# NEXT_PUBLIC_LOGIN_WELCOME="Welcome Save Rack"
